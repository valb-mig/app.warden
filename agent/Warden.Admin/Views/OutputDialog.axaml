<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Warden.Admin.Views.OutputDialog"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <TextBlock Name="TitleText" DockPanel.Dock="Top" FontWeight="Bold" Margin="0,0,0,10" TextWrapping="Wrap" />
        <ScrollViewer>
            <TextBlock Name="OutputText" FontFamily="monospace" TextWrapping="Wrap" />
        </ScrollViewer>
    </DockPanel>
</Window>
