<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Warden.Admin.Views.ConfirmDialog"
        Width="380" SizeToContent="Height" CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Confirmar">
    <StackPanel Margin="20" Spacing="16">
        <TextBlock Name="TitleText" FontSize="15" FontWeight="Bold" TextWrapping="Wrap" />
        <TextBlock Name="MessageText" TextWrapping="Wrap" Opacity="0.8" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button Name="CancelButton" Content="Cancelar" Click="OnCancelClick" />
            <Button Name="ConfirmButton" Content="Rodar" Click="OnConfirmClick" Classes="accent" />
        </StackPanel>
    </StackPanel>
</Window>
