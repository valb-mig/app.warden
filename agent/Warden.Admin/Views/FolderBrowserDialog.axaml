<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Warden.Admin.ViewModels"
        xmlns:disc="using:Warden.Contracts.Discovery"
        xmlns:conv="using:Warden.Admin.Converters"
        x:Class="Warden.Admin.Views.FolderBrowserDialog"
        x:DataType="vm:FolderBrowserViewModel"
        Width="480" Height="480"
        WindowStartupLocation="CenterOwner"
        Title="Escolher pasta">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="0,0,0,10">
            <TextBlock Text="{Binding CurrentPath}" FontFamily="monospace" FontSize="11" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="↑ Subir" Command="{Binding NavigateUpCommand}"
                        IsEnabled="{Binding ParentPath, Converter={x:Static conv:IsNotNullConverter.Instance}}" />
                <TextBlock Text="{Binding ErrorMessage}" Foreground="#F87171" VerticalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Name="CancelButton" Content="Cancelar" Click="OnCancelClick" />
            <Button Name="ChooseButton" Content="Usar esta pasta" Click="OnChooseClick" Classes="accent" />
        </StackPanel>

        <ListBox Name="EntriesList" ItemsSource="{Binding Entries}" DoubleTapped="OnEntryDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="disc:BrowseEntryDto">
                    <TextBlock Text="{Binding Name}" ToolTip.Tip="{Binding Path}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
